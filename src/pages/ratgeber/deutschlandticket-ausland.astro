            <th style="padding:.5rem .75rem">Grenztarifpunkt</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td style="padding:.5rem .75rem">Niebüll → Tønder</td>
            <td style="padding:.5rem .75rem">NEG</td>
            <td style="padding:.5rem .75rem">Tønder</td>
          </tr>
        </tbody>
      </table>
    </div>

