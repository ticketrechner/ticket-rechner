          </tr>
        </thead>
        <tbody>
          <tr style="border-bottom:1px solid var(--line)">
            <td style="padding:.5rem .75rem">Kaldenkirchen → Venlo</td>
            <td style="padding:.5rem .75rem">eurobahn</td>
            <td style="padding:.5rem .75rem">Venlo</td>
          </tr>
          <tr style="border-bottom:1px solid var(--line)">
            <td style="padding:.5rem .75rem">Bad Bentheim → Hengelo</td>
            <td style="padding:.5rem .75rem">eurobahn</td>
            <td style="padding:.5rem .75rem">Hengelo</td>
          </tr>
          <tr style="border-bottom:1px solid var(--line)">
            <td style="padding:.5rem .75rem">Gronau (Westf) → Enschede</td>
