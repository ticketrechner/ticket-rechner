const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Deutschlandticket als Jobticket 2026: nur 44,10 € — so geht's",
    "datePublished": "2026-07-19",
    "dateModified": "2026-07-19",
    "inLanguage": "de",
    "author": { "@type": "Organization", "name": "Redaktion ticket-rechner.de" },
    "publisher": { "@type": "Organization", "name": "ticket-rechner.de" },
    "mainEntityOfPage": "https://ticket-rechner.de/ratgeber/deutschlandticket-jobticket"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Was kostet das Deutschlandticket als Jobticket 2026?", "acceptedAnswer": { "@type": "Answer", "text": "Maximal 44,10 € pro Monat: Der Arbeitgeber zahlt mindestens 25 % des Ticketpreises (15,75 €) dazu, zusätzlich gibt es 5 % Rabatt (3,15 €) auf den Ausgabepreis von 63 €. Zahlt der Arbeitgeber mehr — bis zu 100 % — sinkt dein Eigenanteil entsprechend." } },
      { "@type": "Question", "name": "Kann ich das Jobticket auch privat nutzen?", "acceptedAnswer": { "@type": "Answer", "text": "Ja, uneingeschränkt. Das Jobticket ist ein normales Deutschlandticket und gilt bundesweit — auch am Wochenende, im Urlaub und für Freizeitfahrten." } },
      { "@type": "Question", "name": "Ist das Deutschlandticket-Jobticket steuerfrei?", "acceptedAnswer": { "@type": "Answer", "text": "Ja. Der Arbeitgeberzuschuss zum Jobticket ist gemäß § 3 Nr. 15 EStG steuer- und sozialabgabenfrei — für Arbeitgeber wie Arbeitnehmer ein Vorteil gegenüber einer Gehaltserhöhung in gleicher Höhe." } },
      { "@type": "Question", "name": "Was passiert mit dem Jobticket beim Jobwechsel?", "acceptedAnswer": { "@type": "Answer", "text": "Mit dem Ende des Arbeitsverhältnisses musst du das Jobticket kündigen — es hängt am Rahmenvertrag deines Arbeitgebers. Auch hier gilt die übliche Frist zum 10. des Monats. Danach kannst du nahtlos ein reguläres Deutschlandticket abschließen." } }
    ]
  }
];
---
<Base
  title="Deutschlandticket Jobticket 2026: nur 44,10 € — so bekommst du es"
  description="Deutschlandticket als Jobticket: max. 44,10 € statt 63 € — Arbeitgeber zahlt 25 %, plus 5 % Rabatt, steuerfrei nach § 3 Nr. 15 EStG. So fragst du richtig nach."
  schema={schema}
>
  <article class="container--narrow" style="padding:2rem 0 1rem">
    <p style="color:var(--brand);font-weight:800;letter-spacing:.06em;text-transform:uppercase;font-size:.8rem;margin:0">
      Ratgeber · Aktualisiert am 19.07.2026
    </p>
    <h1>Deutschlandticket als Jobticket: nur 44,10 € statt 63 €</h1>
    <p style="color:var(--ink-soft)">
      Das Jobticket ist die günstigste Art, als Berufstätiger an das Deutschlandticket
      zu kommen: <strong>maximal 44,10 € im Monat</strong> — fast 19 € unter dem
      Normalpreis. Der Haken? Es gibt keinen, außer dass du deinen Arbeitgeber
      aktiv fragen musst. Viele wissen gar nicht, dass ihre Firma längst mitmacht.
    </p>

    <h2>So kommt der Preis zustande</h2>
    <p>
      Die Rechnung ist einfach: Der Ausgabepreis liegt bei <strong>63 €</strong>.
      Zahlt dein Arbeitgeber mindestens <strong>25 %</strong> dazu (das sind 15,75 €),
      gewähren die Verkehrsunternehmen zusätzlich <strong>5 % Rabatt</strong> auf den
      Ticketpreis (3,15 €). Bleiben für dich: <strong>63 − 15,75 − 3,15 = 44,10 €</strong>.
      Und das ist nur das Minimum — dein Arbeitgeber kann auch 50 % oder gleich
      100 % übernehmen. Bei vollem Zuschuss fährst du komplett kostenlos.
    </p>

    <h2>Der Steuer-Trick, der beide Seiten überzeugt</h2>
    <p>
      Der Arbeitgeberzuschuss ist nach <strong>§ 3 Nr. 15 EStG steuer- und
      sozialabgabenfrei</strong>. Das heißt: 15,75 € Jobticket-Zuschuss kommen bei dir
      1:1 an — eine Gehaltserhöhung in gleicher Höhe würde nach Steuern und Abgaben
      deutlich zusammenschmelzen. Auch für die Firma ist der Zuschuss günstiger als
      Bruttolohn. Genau mit diesem Argument überzeugst du eine zögernde
      Personalabteilung.
    </p>

    <h2>So bekommst du das Jobticket — Schritt für Schritt</h2>
    <p>
      Voraussetzung ist, dass dein Arbeitgeber einen <strong>Rahmenvertrag</strong> mit
      einem Verkehrsunternehmen oder Verbund abgeschlossen hat. Dann läuft es so:
      Du erhältst von der Firma einen Bestellcode oder Zugang zum
      <strong>Firmenportal</strong>, bestellst dort dein persönliches Deutschlandticket,
      und der Eigenanteil wird meist direkt über die Gehaltsabrechnung eingezogen.
      Gibt es noch keinen Rahmenvertrag? Frag bei HR nach — der Abschluss ist für
      Unternehmen unkompliziert, und schon ab wenigen Teilnehmern möglich.
    </p>

    <h2>Voll privat nutzbar — kein „Arbeitswege-Ticket"</h2>
    <p>
      Wichtig zu wissen: Das Jobticket ist ein <strong>ganz normales
      Deutschlandticket</strong>. Es gilt bundesweit, rund um die Uhr — am Wochenende,
      im Urlaub, für jeden privaten Ausflug. Es ist nicht auf den Arbeitsweg
      beschränkt und auch nicht auf Vollzeitkräfte. Die üblichen Grenzen gelten
      natürlich auch hier: <a href="/ratgeber/deutschlandticket-ice">kein
      Fernverkehr</a>, keine 1. Klasse, personengebunden.
    </p>

    <h2>Jobwechsel oder Kündigung: daran denken</h2>
    <p>
      Das Jobticket hängt am Rahmenvertrag deines Arbeitgebers. Endet dein
      Arbeitsverhältnis, musst du das Ticket kündigen — und auch hier gilt die
      <a href="/kuendigungsfrist-rechner">Frist zum 10. des Monats</a>. Danach kannst
      du nahtlos ein reguläres Deutschlandticket für 63 € abschließen (oder beim neuen
      Arbeitgeber wieder ein Jobticket beantragen). Für das Kündigungsschreiben
      hilft dir unser <a href="/kuendigungsschreiben">Generator</a>.
    </p>

    <h2>Lohnt sich das Jobticket immer?</h2>
    <p>
      Bei 44,10 € liegt die Schwelle deutlich niedriger als beim Normalpreis: Schon
      <strong>13 Einzelfahrten im Monat</strong> à 3,50 € machen das Ticket rentabel —
      das sind gerade einmal 7 Pendeltage. Wer auch nur halbwegs regelmäßig mit Bus
      oder Bahn zur Arbeit fährt, spart praktisch immer. Rechne deinen konkreten Fall
      im <a href="/lohnt-sich-rechner">Lohnt-sich-Rechner</a> durch.
    </p>

    <p style="color:var(--ink-soft);font-size:.9rem;margin-top:2.5rem">
      Redaktion ticket-rechner.de · Quellen: Bundesregierung, § 3 Nr. 15 EStG,
      Verbund-Angaben. Alle Angaben ohne Gewähr, keine Steuerberatung.
      Preisstand: 63 €/Monat (regulär) seit 01.01.2026.
    </p>
  </article>
</Base>
