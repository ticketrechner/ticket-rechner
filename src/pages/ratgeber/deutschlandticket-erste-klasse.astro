    "mainEntity": [
      { "@type": "Question", "name": "Gilt das Deutschlandticket in der 1. Klasse?", "acceptedAnswer": { "@type": "Answer", "text": "Nein. Das Deutschlandticket gilt ausschließlich in der 2. Klasse — auch in Regionalzügen, S-Bahnen und allen anderen Verkehrsmitteln." } },
      { "@type": "Question", "name": "Kann ich ein Upgrade auf die 1. Klasse kaufen?", "acceptedAnswer": { "@type": "Answer", "text": "Es gibt kein bundesweites 1.-Klasse-Upgrade. Einzelne Verkehrsverbünde bieten regionale Aufpreise an — zum Beispiel der HVV (3,70 € pro Fahrt oder 54,30 € pro Monat) und der RMV. Diese gelten nur im jeweiligen Verbundgebiet." } },
      { "@type": "Question", "name": "Was passiert, wenn ich mit dem Deutschlandticket in der 1. Klasse sitze?", "acceptedAnswer": { "@type": "Answer", "text": "Du giltst als Fahrgast ohne gültigen Fahrschein für die 1. Klasse. Es droht ein erhöhtes Beförderungsentgelt von 60 €. Bei Kulanz wirst du aufgefordert, in die 2. Klasse zu wechseln." } },
      { "@type": "Question", "name": "Gilt das Deutschlandticket in der 1. Klasse der S-Bahn?", "acceptedAnswer": { "@type": "Answer", "text": "Nein. Die 2.-Klasse-Regel gilt für alle Verkehrsmittel, die das Deutschlandticket abdeckt — auch für S-Bahnen. In manchen Städten haben S-Bahnen allerdings gar keine 1. Klasse." } },
      { "@type": "Question", "name": "Kann ich ein 1.-Klasse-Upgrade im Zug kaufen?", "acceptedAnswer": { "@type": "Answer", "text": "In der Regel nein. Die regionalen 1.-Klasse-Upgrades müssen vorher gekauft werden — in der App, am Automaten oder am Schalter. Im Zug selbst gibt es diese Option meist nicht." } },
