const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Deutschlandticket 1. Klasse: geht das? Upgrade-Regeln 2026",
    "datePublished": "2026-07-19",
    "dateModified": "2026-07-19",
    "inLanguage": "de",
    "author": { "@type": "Organization", "name": "Redaktion ticket-rechner.de" },
    "publisher": { "@type": "Organization", "name": "ticket-rechner.de" },
    "mainEntityOfPage": "https://ticket-rechner.de/ratgeber/deutschlandticket-erste-klasse"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Gilt das Deutschlandticket in der 1. Klasse?", "acceptedAnswer": { "@type": "Answer", "text": "Nein. Das Deutschlandticket gilt ausschließlich in der 2. Klasse — auch in Regionalzügen, S-Bahnen und allen anderen Verkehrsmitteln." } },
      { "@type": "Question", "name": "Kann ich ein Upgrade auf die 1. Klasse kaufen?", "acceptedAnswer": { "@type": "Answer", "text": "Es gibt kein bundesweites 1.-Klasse-Upgrade. Einzelne Verkehrsverbünde bieten regionale Aufpreise an, die aber nur im jeweiligen Verbundgebiet gelten — nicht deutschlandweit." } },
      { "@type": "Question", "name": "Was passiert, wenn ich mit dem Deutschlandticket in der 1. Klasse sitze?", "acceptedAnswer": { "@type": "Answer", "text": "Du giltst als Fahrgast ohne gültigen Fahrschein für die 1. Klasse. Je nach Kontrolleur wirst du aufgefordert, in die 2. Klasse zu wechseln, oder es wird ein erhöhtes Beförderungsentgelt erhoben." } }
