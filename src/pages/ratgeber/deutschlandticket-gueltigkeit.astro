    "inLanguage": "de",
    "author": { "@type": "Organization", "name": "Redaktion ticket-rechner.de" },
    "publisher": { "@type": "Organization", "name": "ticket-rechner.de" },
    "mainEntityOfPage": "https://ticket-rechner.de/ratgeber/deutschlandticket-gueltigkeit"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Wo gilt das Deutschlandticket?", "acceptedAnswer": { "@type": "Answer", "text": "Bundesweit im gesamten öffentlichen Nah- und Regionalverkehr: Regionalzüge (RE, RB), S-Bahnen, U-Bahnen, Straßenbahnen und Busse aller teilnehmenden Verkehrsunternehmen — unabhängig von Bundesland und Verbund. Teils gilt es auch auf Fähren des ÖPNV." } },
      { "@type": "Question", "name": "Wo gilt das Deutschlandticket nicht?", "acceptedAnswer": { "@type": "Answer", "text": "Nicht im Fernverkehr (ICE, IC, EC), nicht bei privaten Fernanbietern wie FlixTrain und FlixBus, nicht in der 1. Klasse und grundsätzlich nicht im Ausland — mit einzelnen grenznahen Ausnahmen." } },
      { "@type": "Question", "name": "Gilt das Deutschlandticket im Ausland?", "acceptedAnswer": { "@type": "Answer", "text": "Grundsätzlich nein, aber es gibt grenznahe Ausnahmen. Aktuell gilt es z. B. vom 1. Juli bis 31. August 2026 in der französischen Région Grand Est in TER-Regionalzügen und Regionalbussen — nur mit Ausweis, teils mit Reservierungspflicht, nicht im TGV und nicht im Stadtverkehr." } },
