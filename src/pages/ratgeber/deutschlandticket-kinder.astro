          <tr style="border-bottom:1px solid var(--line)">
            <td style="padding:.5rem .75rem">Niedersachsen (Hannover)</td>
            <td style="padding:.5rem .75rem">30,40 €</td>
            <td style="padding:.5rem .75rem">Ja</td>
            <td style="padding:.5rem .75rem">Deutschlandticket Hannover Jugend, regional</td>
          </tr>
          <tr>
            <td style="padding:.5rem .75rem">Übrige Bundesländer</td>
            <td style="padding:.5rem .75rem">63 € (Vollpreis)</td>
            <td style="padding:.5rem .75rem">Ja</td>
            <td style="padding:.5rem .75rem">Teilweise regionale Einzelangebote</td>
          </tr>
        </tbody>
