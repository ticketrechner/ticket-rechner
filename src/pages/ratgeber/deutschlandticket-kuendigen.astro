    "datePublished": "2026-07-19",
    "dateModified": "2026-07-19",
    "inLanguage": "de",
    "author": { "@type": "Organization", "name": "Redaktion ticket-rechner.de" },
    "publisher": { "@type": "Organization", "name": "ticket-rechner.de" },
    "mainEntityOfPage": "https://ticket-rechner.de/ratgeber/deutschlandticket-kuendigen"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Wie kündige ich das Deutschlandticket?", "acceptedAnswer": { "@type": "Answer", "text": "Am schnellsten kündigst du dort, wo du das Ticket gekauft hast: in der App oder im Abo-Portal deines Anbieters, meist unter 'Abo verwalten' oder 'Vertrag kündigen'. Alternativ per E-Mail an den Kundenservice. Die Kündigung muss bei den meisten Anbietern bis zum 10. des Monats eingehen." } },
      { "@type": "Question", "name": "Bis wann muss ich das Deutschlandticket kündigen?", "acceptedAnswer": { "@type": "Answer", "text": "Standard ist der 10. des Monats: Geht die Kündigung bis dahin ein, endet das Ticket zum Monatsende. Danach läuft es einen Monat weiter — und kostet weitere 63 €." } },
      { "@type": "Question", "name": "Kann ich das Deutschlandticket monatlich kündigen?", "acceptedAnswer": { "@type": "Answer", "text": "Ja. Das Deutschlandticket ist ein monatlich kündbares Abo ohne Mindestlaufzeit. Es gibt keine Kündigungsgebühr." } },
      { "@type": "Question", "name": "Kostet die Kündigung des Deutschlandtickets etwas?", "acceptedAnswer": { "@type": "Answer", "text": "Nein, die Kündigung ist kostenlos. Du zahlst nur die Monate, in denen das Abo aktiv war." } },
      { "@type": "Question", "name": "Kann ich das Deutschlandticket wegen der Preiserhöhung außerordentlich kündigen?", "acceptedAnswer": { "@type": "Answer", "text": "Die Anbieter berufen sich darauf, dass die Preiserhöhung zum Januar 2026 eine politisch vorgegebene Tarifanpassung ist und kein Sonderkündigungsrecht auslöst. Da das Ticket ohnehin monatlich kündbar ist, ist die reguläre Kündigung zum Monatsende der einfachste Weg." } },
      { "@type": "Question", "name": "Kann ich das Deutschlandticket pausieren statt kündigen?", "acceptedAnswer": { "@type": "Answer", "text": "Ein offizielles Pausieren gibt es nicht. Da das Abo monatlich kündbar ist und du es jederzeit neu abschließen kannst, funktioniert Kündigen und späteres Neu-Abonnieren wie eine Pause — nur die Frist zum 10. musst du im Blick behalten." } }
