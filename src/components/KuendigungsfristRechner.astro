---
// Kündigungsfrist-Rechner — Deutschlandticket
// Rule: cancellation must reach the provider by the 10th of a month (most providers)
// to take effect at the end of that same month. Some providers use the 15th or
// month-end — selectable below.
---
<section class="card" id="kfr" aria-labelledby="kfr-title">
  <h2 id="kfr-title" style="margin-top:0">Kündigungsfrist-Rechner</h2>
  <p style="color:var(--ink-soft);margin-top:0">
    Bis wann musst du kündigen, damit dein Deutschlandticket zum Monatsende endet?
  </p>

  <label for="kfr-date">Heutiges Datum (oder geplantes Kündigungsdatum)</label>
  <input type="date" id="kfr-date" />

  <label for="kfr-frist">Kündigungsfrist deines Anbieters</label>
  <select id="kfr-frist">
    <option value="10" selected>Zum 10. des Monats (Standard, z. B. DB, RMV, HVV)</option>
    <option value="15">Zum 15. des Monats (einige Verbünde)</option>
    <option value="eom">Bis Monatsende (z. B. mo.pla, einige Abo-Portale)</option>
  </select>

  <div style="margin-top:1.1rem">
    <button class="btn" id="kfr-btn" type="button">Frist berechnen</button>
  </div>

  <div id="kfr-result" role="status" aria-live="polite"></div>
</section>

<script>
  const MONTHS = ['Januar','Februar','März','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'];
  const fmt = (d) => `${d.getDate()}. ${MONTHS[d.getMonth()]} ${d.getFullYear()}`;

  const dateEl = document.getElementById('kfr-date');
  const fristEl = document.getElementById('kfr-frist');
  const out = document.getElementById('kfr-result');

  // Default: today
  const today = new Date();
  dateEl.value = today.toISOString().slice(0, 10);

  function calc() {
    const val = dateEl.value;
    if (!val) { out.innerHTML = ''; return; }
    const d = new Date(val + 'T12:00:00');
    const frist = fristEl.value;
    const y = d.getFullYear(), m = d.getMonth();
    const lastOfMonth = new Date(y, m + 1, 0);
    const lastOfNext = new Date(y, m + 2, 0);

    let deadline, effective, missed;
    if (frist === 'eom') {
      deadline = lastOfMonth;
      missed = false; // any day this month still counts
    } else {
      const day = parseInt(frist, 10);
      deadline = new Date(y, m, day);
      missed = d.getDate() > day;
    }

    if (!missed) {
      effective = lastOfMonth;
      out.innerHTML = `
        <div class="result result--ok">
          <h3>Du bist noch rechtzeitig ✅</h3>
          <p style="margin:.2rem 0">Kündige spätestens am <span class="big">${fmt(deadline)}</span>.</p>
          <p style="margin:.2rem 0">Dein Ticket endet dann zum <strong>${fmt(effective)}</strong> — du zahlst keinen weiteren Monat.</p>
        </div>`;
    } else {
      const nextDeadline = frist === 'eom' ? lastOfNext : new Date(y, m + 1, parseInt(frist, 10));
      effective = lastOfNext;
      out.innerHTML = `
        <div class="result result--warn">
          <h3>Frist für diesen Monat verpasst ⚠️</h3>
          <p style="margin:.2rem 0">Die Frist war der <strong>${fmt(deadline)}</strong>. Deine Kündigung wirkt jetzt zum <span class="big">${fmt(effective)}</span>.</p>
          <p style="margin:.2rem 0">Nächste Deadline: <strong>${fmt(nextDeadline)}</strong>. Tipp: Kündige trotzdem sofort — die Kündigung gilt automatisch zum nächstmöglichen Termin.</p>
        </div>`;
    }
  }

  document.getElementById('kfr-btn').addEventListener('click', calc);
  dateEl.addEventListener('change', calc);
  fristEl.addEventListener('change', calc);
  calc();
</script>
