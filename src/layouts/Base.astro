---
import '../styles/global.css';
interface Props {
  title: string;
  description: string;
  schema?: object | object[];
}
const { title, description, schema } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="de_DE" />
  <meta property="og:image" content="https://ticket-rechner.de/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://ticket-rechner.de/og-image.png" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <meta name="google-site-verification" content="8E0by14vur5uZ_JZRApTR-F0kV8BwVurdqWkhRlau2o" />
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a class="logo" href="/">ticket-rechner<span class="tld">.de</span><span class="logo-badge">D-Ticket</span></a>
      <nav class="main-nav" aria-label="Hauptnavigation">
        <a href="/kuendigungsfrist-rechner">Kündigungsfrist</a>
        <a href="/lohnt-sich-rechner">Lohnt es sich?</a>
        <a href="/kuendigungsschreiben">Kündigungsschreiben</a>
        <a href="/ratgeber">Ratgeber</a>
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer class="site-footer">
    <div class="container">
      <span>© {new Date().getFullYear()} ticket-rechner.de — Unabhängiges Informationsportal. Keine offizielle Seite der Deutschen Bahn oder eines Verkehrsverbunds.</span>
      <span>
        <a href="/ueber-uns">Über uns</a> ·
        <a href="/kontakt">Kontakt</a> ·
        <a href="/impressum">Impressum</a> ·
        <a href="/datenschutz">Datenschutz</a>
      </span>
    </div>
  </footer>
</body>
</html>
